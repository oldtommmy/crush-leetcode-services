# Crush LeetCode services root env example.
# Copy app-specific values into apps/mailer/.env.local for local runtime.

MAILER_BASE_URL=https://mailer.example.com
MAILER_PORT=8787

BREVO_API_KEY=replace-with-your-brevo-api-key
BREVO_FROM_EMAIL=review@example.com
BREVO_FROM_NAME=Crush LeetCode

REMINDER_SHARED_SECRET=replace-with-a-long-random-string
BETA_CODE_SIGNING_SECRET=replace-with-a-long-random-string
BETA_ADMIN_SECRET=replace-with-a-long-random-string
BETA_ADMIN_USERNAME=admin
BETA_ADMIN_PASSWORD=replace-with-admin-login-password
BETA_ADMIN_SESSION_SECRET=replace-with-a-long-random-session-secret
BETA_DB_PATH=.data/mailer.sqlite
